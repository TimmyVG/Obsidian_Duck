filters:
  and:
    - file.tags.contains("Skill-Tree-Upgrade")
views:
  - type: table
    name: Table
    filters:
      and:
        - file.inFolder("remote-duck/Design/SkillTree/Upgrades")
    order:
      - file.basename
      - Max-Level
      - Type
    sort:
      - property: Max-Level
        direction: ASC
      - property: file.name
        direction: ASC
    columnSize:
      note.Max-Level: 129
  - type: table
    name: View
